[gd_scene load_steps=16 format=3 uid="uid://b0embergrave_s1yard_slice_chunk"]

; S1 open cloister-YARD first-slice chunk (ticket 86ca5erzk, S1-YARD T4).
; The first WALKABLE yard: an open cobble expanse (1280x768 — wider+taller than
; the 480x270 viewport, so the camera scrolls in both axes) with cloister
; buildings as solid landmark structures and the carried-forward props placed as
; landmarks. The S1YardChunk painter paints the cobble floor + finer-brick
; buildings + jittered grass at _ready; this .tscn declares the node skeleton +
; the prop landmarks. Consumed by Main._load_s1_zone via the FloorAssembler path
; (s1_z1_yard_slice ZoneDef), soak-gated behind ?s1_assembler=1.
;
; Z-order (html5-export.md §Z-index — floor z=0, structures/props z=+1, player
; above). v5 AUTOTILE-TERRAIN ground (86ca5hwmx, Sponsor-approved AI-gen Wang +
; Godot autotile pipeline):
;   GroundTerrain z=-1 — the dirt+grass BASE, painted via set_cells_terrain_connect
;     over the doctrine-locked Wang TERRAIN TileSet (s1_dirtgrass_terrain.tres). Godot
;     auto-selects the SOFT BLENDED corner tile wherever dirt meets grass (Stardew/
;     Graveyard-Keeper blend). 32px terrain cells (the blend happens at cell scale, as
;     in the refs). This replaces the v4 hash-dither full-bleed dirt/grass fields.
;   FloorTiles z=0 — the surviving-paving COBBLE apron ONLY (the loved procedural
;     cobble, NOT the weak Wang cobble), 16px fine cells. Opaque, renders OVER the
;     terrain base. No dirt/grass here anymore (the terrain layer owns the base ground).
;   PathLane z=0 — the fine-cobble LANE (loved procedural cobble lane), 16px fine cells.
;     Opaque, renders OVER the terrain base (AC9: exactly one VISIBLE tile-class per cell
;     — the opaque lane/apple cover the terrain beneath; no z-fight, the layers are
;     z-ordered not stacked-at-equal-z).
;   Springs z=0 (ColorRect still-water pools, floor-level); Buildings z=1;
;   BuildingBodies (collision, invisible); Decoration z=1;
;   Props z=2 (read above buildings — braziers/pillars/well on faces/landmarks).

[ext_resource type="Script" path="res://scripts/levels/S1YardChunk.gd" id="1_yard"]
[ext_resource type="TileSet" path="res://resources/tilesets/s1_cloister_yard.tres" id="2_yardset"]
[ext_resource type="TileSet" path="res://resources/tilesets/s1_dirtgrass_terrain.tres" id="9_dgterrain"]
[ext_resource type="Texture2D" path="res://assets/props/s1_cloister/pillar_arch.png" id="3_pillar"]
[ext_resource type="Texture2D" path="res://assets/props/s1_cloister/brazier_lit.png" id="4_brazier"]
[ext_resource type="Texture2D" path="res://assets/props/s1_cloister/banner_worn.png" id="5_banner"]
[ext_resource type="Texture2D" path="res://assets/props/s1_cloister/rubble_01.png" id="6_rubble"]
[ext_resource type="Texture2D" path="res://assets/props/s1_cloister/parchment_01.png" id="7_parchment"]
[ext_resource type="Texture2D" path="res://assets/props/s1_cloister/well_head.png" id="8_well"]
; v6 APPROVED-LAYOUT building assets (s1-yard-building-assets.md) — PixelLab iso/oblique
; top-down weathered-cloister-stone structures, placed as z=+1 Sprite2D landmarks at the
; §3.1 footprints. The dormitory is TWO distinct ruin sprites (orch decision) over the
; Rect2i(0,21,15,3) S-edge footprint.
[ext_resource type="Texture2D" path="res://assets/props/s1_yard/chapel_belltower.png" id="10_chapel"]
[ext_resource type="Texture2D" path="res://assets/props/s1_yard/dormitory_ruin_left.png" id="11_dormL"]
[ext_resource type="Texture2D" path="res://assets/props/s1_yard/dormitory_ruin_right.png" id="12_dormR"]
[ext_resource type="Texture2D" path="res://assets/props/s1_yard/cloister_central.png" id="13_central"]
[ext_resource type="Texture2D" path="res://assets/props/s1_yard/outbuilding_far.png" id="14_outb"]

[node name="S1YardSliceChunk" type="Node2D"]
script = ExtResource("1_yard")

; GroundTerrain — the dirt+grass autotiled BASE (v5). Painted by
; S1YardChunk._paint_ground_terrain via set_cells_terrain_connect over the
; doctrine-locked Wang TERRAIN TileSet (32px corner-match). Godot auto-selects the
; soft blended edge tile per corner pattern. z=-1 (below the cobble apron + lane).
[node name="GroundTerrain" type="TileMapLayer" parent="."]
z_index = -1
texture_filter = 1
tile_set = ExtResource("9_dgterrain")

[node name="FloorTiles" type="TileMapLayer" parent="."]
texture_filter = 1
tile_set = ExtResource("2_yardset")

; Fine-cobble LANE (the v2 path, 86ca5hwmx — replaces the dead ashlar slab). Painted
; by S1YardChunk._paint_path_lane into THIS layer at z=0; the ground cell beneath each
; lane cell is ERASED in FloorTiles so exactly one tile-class renders per cell (no
; stacked-z, no z-fight — AC9 / html5-export.md §Z-index). The lane is finer + warmer-
; lighter than the surrounding ground (the "walk here" wayfinding read, spec §2).
[node name="PathLane" type="TileMapLayer" parent="."]
texture_filter = 1
tile_set = ExtResource("2_yardset")

; Springs — still dark warm-neutral ColorRect pools (S1_YARD_WATER_DOCTRINE) at
; floor level. NO bespoke asset (orch handoff: spring is a ColorRect-pool decoration
; over the cobble). z=0 floor-level. SOAK-REVISION (#426): the moss_patch sprite rings
; (+ garden overgrowth + apron tufts) were REMOVED — the Sponsor flagged those spiky
; moss sprites as ugly "trash". This container now holds only ColorRects (pools, glints,
; the garden soil bed, the apron shadow strips) — NO Sprite2D props.
[node name="Springs" type="Node2D" parent="."]

; v6: the Buildings TileMapLayer is NO LONGER painted (the painter dropped finer-brick — the
; flat brick read flat + clashed with the iso building sprites). Kept (empty) for node-skeleton
; back-compat; the building VISUAL is now the BuildingSprites group below.
[node name="Buildings" type="TileMapLayer" parent="."]
z_index = 1
texture_filter = 1
tile_set = ExtResource("2_yardset")

; --- v6 APPROVED-LAYOUT building sprites (s1-yard-building-assets.md §4). Iso/oblique
; top-down PixelLab structures placed at the §3.1 footprints; centered=false so position is
; the sprite TOP-LEFT, scaled so sprite WIDTH ≈ footprint width, offset UP so the ground-
; contact BASE sits at the footprint bottom edge and the mass (walls/roof/bell-tower) rises
; toward screen-N (up). z=1 (above floor z=0, below the small face-props at z=2). ---
[node name="BuildingSprites" type="Node2D" parent="."]
z_index = 1

; Chapel + bell-tower — NW-corner-at-spawn (footprint x0-7,y0-2). Scale 1.0667 (240→256px
; width), sprite 256x256, top-left (0,-160) so the bell-tower rises off-frame N, base at y96.
[node name="Chapel" type="Sprite2D" parent="BuildingSprites"]
texture_filter = 1
centered = false
position = Vector2(0, -160)
scale = Vector2(1.0667, 1.0667)
texture = ExtResource("10_chapel")

; Dormitory ruin — LEFT (more-intact end), covers footprint x0-7. Scale 1.0407, top-left
; (0,517) so the base sits at the S grid edge y768 (runs off-frame S).
[node name="DormitoryLeft" type="Sprite2D" parent="BuildingSprites"]
texture_filter = 1
centered = false
position = Vector2(0, 517)
scale = Vector2(1.0407, 1.0407)
texture = ExtResource("11_dormL")

; Dormitory ruin — RIGHT (more-collapsed end + rubble spill), covers footprint x7-14 (abuts
; the left half at x7). Scale 1.0492, top-left (224,512), base at y768.
[node name="DormitoryRight" type="Sprite2D" parent="BuildingSprites"]
texture_filter = 1
centered = false
position = Vector2(224, 512)
scale = Vector2(1.0492, 1.0492)
texture = ExtResource("12_dormR")

; Central cloister building — high, off-center (footprint x26-29,y0-3). Its LIT SOUTH WINDOW
; (baked into the PNG) faces the player approach (canvas-S). Scale 1.0756, top-left (832,14).
[node name="CentralBuilding" type="Sprite2D" parent="BuildingSprites"]
texture_filter = 1
centered = false
position = Vector2(832, 14)
scale = Vector2(1.0756, 1.0756)
texture = ExtResource("13_central")

; Far outbuilding — tiny east-horizon depth anchor (footprint x38-39,y2-3). Scale 0.7901,
; top-left (1216,70), sits ABOVE the exit line (y12) so it doesn't block the descent approach.
[node name="Outbuilding" type="Sprite2D" parent="BuildingSprites"]
texture_filter = 1
centered = false
position = Vector2(1216, 70)
scale = Vector2(0.7901, 0.7901)
texture = ExtResource("14_outb")

[node name="BuildingBodies" type="Node2D" parent="."]

; Collision body for the well-head landmark (solid like buildings). Built by the
; painter (footprint mirrored in the nav GUT test) so the well is walk-AROUND.
[node name="WellBody" type="Node2D" parent="."]

[node name="Decoration" type="Node2D" parent="."]
