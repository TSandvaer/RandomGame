[gd_scene load_steps=4 format=3 uid="uid://b0embergrave_archive_sentinel"]

; W3-T7 — Archive Sentinel boss scene (ticket 86c9y7ygj Part D).
;
; Sprite-swap (devon/archive-sentinel-v3-spriteswap): the Stage-5 placeholder
; ColorRect has been replaced with the Sponsor-approved PixelLab v3 art, wired
; as a STATIC Sprite2D facing south. The Archive Sentinel is a STATIONARY
; frontal construct (Uma §5.5 "head-on facing camera") — its telegraphs
; (cast / slam / phase) are CODE-DRAWN (`_draw()` / `draw_arc()` slam circle,
; CPUParticles2D ember bursts, modulate flares), NOT sprite-frame animations.
; So a single south-facing static sprite suffices — there are no required
; named frame-animations.
;
; Source art: PixelLab char ca44536c-e033-4d02-a104-3f7f3df1d4cc, v3 rotation
; set (140x140, low top-down). The 8 rotations are kept in-repo under
; `_pixellab_anims/Archive-Sentinel-v3/rotations/` for future use even though
; only `south` is wired (a stationary boss faces the player). The reverse-map
; lives at `assets/sprites/ArchiveSentinel/_pixellab_anims/anim-folder-map.md`.
;
; Scale: 140px source canvas at scale 0.57 → ~80px effective canvas, matching
; the S1 boss frame canvas (80x80) so the construct reads at boss scale and is
; consistent with Stratum1Boss. Content (~70px) renders at ~40px body.
;
; texture_filter = 1 (NEAREST) preserves the pixel grid (M3W-1 convention).
;
; ArchiveSentinel.gd's _play_hit_flash / _play_attack_telegraph 3-branch
; resolvers handle a non-ColorRect / non-AnimatedSprite2D child by falling to
; the self.modulate branch (branch 3), which tweens the CharacterBody2D
; modulate — cascading to the Sprite2D child. Hit-flash + telegraph remain
; visible. _play_anim is fully defensive: a non-AnimatedSprite2D child no-ops
; (no broken anim references, no USER ERROR).
;
; CollisionShape2D radius: 24 px (mirrors S1 boss — same plinth footprint the
; player navigates around). The visible sprite is wider than the collision
; shape so the player can graze the visual without contact damage.
;
; collision_layer = 8 (enemy, bit 4), collision_mask = 3 (world bit 1 +
; player bit 2). Same shape as Stratum1Boss + every enemy in the project.
;
; Cross-references:
;   scripts/mobs/ArchiveSentinel.gd (controller)
;   scenes/mobs/Stratum1Boss.tscn (S1 scene precedent)
;   team/uma-ux/palette-stratum-2.md §5.5
;   .claude/docs/pixellab-pipeline.md § "Folder-rename + reverse-map"

[ext_resource type="Script" path="res://scripts/mobs/ArchiveSentinel.gd" id="1_sentinel"]
[ext_resource type="Texture2D" path="res://assets/sprites/ArchiveSentinel/south.png" id="2_sentinel_tex"]

[sub_resource type="CircleShape2D" id="CircleShape2D_sentinel"]
radius = 24.0

[node name="ArchiveSentinel" type="CharacterBody2D"]
collision_layer = 8
collision_mask = 3
script = ExtResource("1_sentinel")

[node name="CollisionShape2D" type="CollisionShape2D" parent="."]
shape = SubResource("CircleShape2D_sentinel")

[node name="Sprite" type="Sprite2D" parent="."]
texture_filter = 1
scale = Vector2(0.57, 0.57)
texture = ExtResource("2_sentinel_tex")
