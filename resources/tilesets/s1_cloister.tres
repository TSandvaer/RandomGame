[gd_resource type="TileSet" load_steps=4 format=3 uid="uid://b0embergrave_s1cloister_tileset"]

; S1 "Outer Cloister" master TileSet — ticket 86ca3h8hn (Uma env-art brief §3/§7.1).
; Two atlas sources, 32px tiles:
;   Source 0 = floor_sandstone.png  → terrain set 0, terrain 0 "sandstone" (paint-by-drag autotile).
;                64x64 = 2x2 atlas (ticket 86ca44p4j — floor stone-pitch shrink; Sponsor
;                f0a8fc8 feel-reject "tiles much much much smaller"). The crafted 128px
;                block was downsampled 2x to 64px so each 32px game cell shows ~2x finer
;                flagstones; painter tiles it at a 2-tile (64px) period (FLOOR_ATLAS_PERIOD).
;   Source 1 = wall_cloister.png    → terrain set 0, terrain 1 "cloister_stone".
;                128x128 = 4x4 atlas, unchanged (running-bond ashlar reads fine at game zoom;
;                Sponsor reject was floor-only — wall left untouched, no scope creep).
; Tile size 32px matches LevelChunkDef.tile_size_px=32 / 15x8 grid.
; Textures referenced by path (project default_texture_filter=0 = Nearest → pixel-art crisp);
; .import files are gitignored and regenerated by headless Godot on first import.
; Palette-locked to S1_ENV_DOCTRINE (brief §6.3) inside the PNGs themselves — the .tres
; only declares geometry + terrain peering, never colour.

[ext_resource type="Texture2D" path="res://assets/tilesets/s1_cloister/floor_sandstone.png" id="1_floor"]
[ext_resource type="Texture2D" path="res://assets/tilesets/s1_cloister/wall_cloister.png" id="2_wall"]

