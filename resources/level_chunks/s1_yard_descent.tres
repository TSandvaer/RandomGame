[gd_resource type="Resource" script_class="LevelChunkDef" load_steps=5 format=3]

; S1 yard EAST descent-cap chunk def (ticket 86ca5erzk, S1-YARD T4). Narrow
; open-cobble strip (6x24 @ 32px = 192x768) capping the east end of the yard
; slice. Mates WEST (entry at y=12) onto s1_yard_slice's EAST exit (y=12) so the
; assembled floor is ONE continuous expanse. No mob_spawns — the descent approach
; is the journey terminus, not a combat arena (s1-cloister-yard.md §2.2 step 5).

[ext_resource type="Script" path="res://scripts/levels/LevelChunkDef.gd" id="1_chunk"]
[ext_resource type="Script" path="res://scripts/levels/ChunkPort.gd" id="3_port"]

[sub_resource type="Resource" id="Resource_entry_port"]
script = ExtResource("3_port")
position_tiles = Vector2i(0, 12)
direction = 3
tag = &"entry"

[sub_resource type="Resource" id="Resource_exit_port"]
script = ExtResource("3_port")
position_tiles = Vector2i(5, 12)
direction = 1
tag = &"exit"

[resource]
script = ExtResource("1_chunk")
id = &"s1_yard_descent"
display_name = "Outer Cloister Yard — Descent Approach"
size_tiles = Vector2i(6, 24)
tile_size_px = 32
scene_path = "res://scenes/levels/chunks/s1_yard_descent_chunk.tscn"
ports = [SubResource("Resource_entry_port"), SubResource("Resource_exit_port")]
mob_spawns = []
