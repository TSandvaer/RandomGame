[gd_resource type="Resource" script_class="LevelChunkDef" load_steps=6 format=3]

; Cinder Vaults — Entry Hall Threshold.
; W3-T7 Stage 4 — S2 chunk authoring (ticket 86c9y7ygj).
;
; Role: the entry anchor chunk for `s2_z1_entry_hall`. First S2 room the
; player sees on descent from S1; substrate-dominant per palette-stratum-2.md
; §1.6 (entry-hall = 80% Cinder substrate, 20% Archive overlay — one
; scholarly waymarker introduces the sub-region without dominating).
;
; Mob mix: 1 Sunken-Scholar (the lone scholarly waymarker — diegetic logic:
; the first scholar the player sees was the one who came down first). No
; Bone-Catalyst here — the bruiser archetype is reserved for the deeper
; zones where the scholarly overlay has corrupted further.
;
; Ports: WEST entry + EAST exit (mating-clean for both leftmost-anchor and
; pool-fill placements per FloorAssembler.OPEN_PORT_TAGS).

[ext_resource type="Script" path="res://scripts/levels/LevelChunkDef.gd" id="1_chunk"]
[ext_resource type="Script" path="res://scripts/levels/MobSpawnPoint.gd" id="2_spawn"]
[ext_resource type="Script" path="res://scripts/levels/ChunkPort.gd" id="3_port"]

[sub_resource type="Resource" id="Resource_s2r1_entry"]
script = ExtResource("3_port")
position_tiles = Vector2i(0, 4)
direction = 3
tag = &"entry"

[sub_resource type="Resource" id="Resource_s2r1_exit"]
script = ExtResource("3_port")
position_tiles = Vector2i(14, 4)
direction = 1
tag = &"exit"

[sub_resource type="Resource" id="Resource_s2r1_scholar"]
script = ExtResource("2_spawn")
position_tiles = Vector2i(11, 4)
mob_id = &"sunken_scholar"

[resource]
script = ExtResource("1_chunk")
id = &"s2_room01"
display_name = "Cinder Vaults — Entry Hall Threshold"
size_tiles = Vector2i(15, 8)
tile_size_px = 32
scene_path = "res://scenes/levels/chunks/s2_room01_chunk.tscn"
ports = [SubResource("Resource_s2r1_entry"), SubResource("Resource_s2r1_exit")]
mob_spawns = [SubResource("Resource_s2r1_scholar")]
