[gd_resource type="Resource" script_class="LevelChunkDef" load_steps=10 format=3]

; S1 bigger-rooms retrofit Stage 1A (ticket 86ca3kpzz). Widened proof chunk
; def: 30x8 tiles (960x256 px) vs the 15x8 single-screen rooms. Points at the
; widened geometry scene s1_room02_wide_chunk.tscn. Mob roster grown 2->4
; grunts (light balance pass — a 2x-wider floor with the old 2-grunt count
; reads empty). Ports keep the W->E traversal axis (entry on WEST edge at
; tile (0,4), exit on EAST edge at tile (29,4)). id stays s1_room02 so
; StratumProgression / ROOM_IDS bookkeeping + save round-trip are unchanged.

[ext_resource type="Script" path="res://scripts/levels/LevelChunkDef.gd" id="1_chunk"]
[ext_resource type="Script" path="res://scripts/levels/MobSpawnPoint.gd" id="2_spawn"]
[ext_resource type="Script" path="res://scripts/levels/ChunkPort.gd" id="3_port"]

[sub_resource type="Resource" id="Resource_r2_entry"]
script = ExtResource("3_port")
position_tiles = Vector2i(0, 4)
direction = 3
tag = &"entry"

[sub_resource type="Resource" id="Resource_r2_exit"]
script = ExtResource("3_port")
position_tiles = Vector2i(29, 4)
direction = 1
tag = &"exit"

[sub_resource type="Resource" id="Resource_r2_grunt_a"]
script = ExtResource("2_spawn")
position_tiles = Vector2i(10, 3)
mob_id = &"grunt"

[sub_resource type="Resource" id="Resource_r2_grunt_b"]
script = ExtResource("2_spawn")
position_tiles = Vector2i(15, 5)
mob_id = &"grunt"

[sub_resource type="Resource" id="Resource_r2_grunt_c"]
script = ExtResource("2_spawn")
position_tiles = Vector2i(21, 3)
mob_id = &"grunt"

[sub_resource type="Resource" id="Resource_r2_grunt_d"]
script = ExtResource("2_spawn")
position_tiles = Vector2i(25, 5)
mob_id = &"grunt"

[resource]
script = ExtResource("1_chunk")
id = &"s1_room02"
display_name = "Outer Cloister — Antechamber (wide)"
size_tiles = Vector2i(30, 8)
tile_size_px = 32
scene_path = "res://scenes/levels/chunks/s1_room02_wide_chunk.tscn"
ports = [SubResource("Resource_r2_entry"), SubResource("Resource_r2_exit")]
mob_spawns = [SubResource("Resource_r2_grunt_a"), SubResource("Resource_r2_grunt_b"), SubResource("Resource_r2_grunt_c"), SubResource("Resource_r2_grunt_d")]
