[gd_resource type="Resource" script_class="LevelChunkDef" load_steps=10 format=3]

; Cinder Vaults — Mining Cart Bay.
; Mob mix per W3 dispatch: 2 Stokers + 1 Charger (heat-blasted variants).
; Stoker is the W3-T3 retinted Grunt — until the soft-retint sprite work
; lands, this resource still emits `&"grunt"` mob_id (the variants don't
; change the mob class — they're palette/silhouette swaps wired through the
; MobRegistry stratum-resolver). Same applies to the Charger.

[ext_resource type="Script" path="res://scripts/levels/LevelChunkDef.gd" id="1_chunk"]
[ext_resource type="Script" path="res://scripts/levels/MobSpawnPoint.gd" id="2_spawn"]
[ext_resource type="Script" path="res://scripts/levels/ChunkPort.gd" id="3_port"]

[sub_resource type="Resource" id="Resource_s2r2_entry"]
script = ExtResource("3_port")
position_tiles = Vector2i(0, 4)
direction = 3
tag = &"entry"

[sub_resource type="Resource" id="Resource_s2r2_exit"]
script = ExtResource("3_port")
position_tiles = Vector2i(14, 4)
direction = 1
tag = &"exit"

[sub_resource type="Resource" id="Resource_s2r2_stoker_a"]
script = ExtResource("2_spawn")
position_tiles = Vector2i(7, 3)
mob_id = &"grunt"

[sub_resource type="Resource" id="Resource_s2r2_stoker_b"]
script = ExtResource("2_spawn")
position_tiles = Vector2i(9, 5)
mob_id = &"grunt"

[sub_resource type="Resource" id="Resource_s2r2_charger"]
script = ExtResource("2_spawn")
position_tiles = Vector2i(11, 4)
mob_id = &"charger"

[resource]
script = ExtResource("1_chunk")
id = &"s2_room02"
display_name = "Cinder Vaults — Mining Cart Bay"
size_tiles = Vector2i(15, 8)
tile_size_px = 32
scene_path = "res://scenes/levels/chunks/s2_room02_chunk.tscn"
ports = [SubResource("Resource_s2r2_entry"), SubResource("Resource_s2r2_exit")]
mob_spawns = [SubResource("Resource_s2r2_stoker_a"), SubResource("Resource_s2r2_stoker_b"), SubResource("Resource_s2r2_charger")]
