[gd_resource type="Resource" script_class="LevelChunkDef" load_steps=8 format=3]

; Cinder Vaults — Archive Vault (Reliquary Hall).
; W3-T7 Stage 4 — S2 chunk authoring (ticket 86c9y7ygj).
;
; Role: the quest_target anchor chunk for `s2_z3_archive_vault` — overlay-
; dominant per palette-stratum-2.md §1.6 (40% Cinder substrate, 60% Archive
; overlay — the deepest functional archive). Mixed mob roster with scholar
; majority reads as "this room was theirs."
;
; Mob mix: 2 Sunken-Scholar (the archive's last readers — flanking
; positions for crossfire pressure) + 1 Bone-Catalyst (the reliquary
; guardian — center-room melee threat).
;
; Ports: WEST entry + EAST exit. Quest_target anchor — Track 3 exploration
; quest (Part E) binds objective resolution here.

[ext_resource type="Script" path="res://scripts/levels/LevelChunkDef.gd" id="1_chunk"]
[ext_resource type="Script" path="res://scripts/levels/MobSpawnPoint.gd" id="2_spawn"]
[ext_resource type="Script" path="res://scripts/levels/ChunkPort.gd" id="3_port"]

