[gd_resource type="Resource" script_class="LevelChunkDef" load_steps=8 format=3]

; Cinder Vaults — Inner Sanctum Threshold.
; W3-T7 Stage 4 — S2 chunk authoring (ticket 86c9y7ygj).
;
; Role: the boss_room anchor chunk for `s2_z4_inner_sanctum`. Final
; corridor before the Stratum2BossRoom encounter (Part D — Archive Sentinel
; arena). Substrate-reclaims weighting per palette-stratum-2.md §1.6 (70%
; Cinder, 30% overlay — the scholarly identity is failing here; the
; cinder is winning).
;
; EAST port carries the `&"boss_door"` tag (mirrors s1_room08 → Stratum1BossRoom
; pattern). The downstream W3-T7 Stage 5 (Stratum2BossRoom) consumes this
; tag to route the player into the boss arena.
;
; Mob mix: 2 Sunken-Scholar (the order's last guards — paired ranged
; pressure at the corridor exits) + 1 Bone-Catalyst (one bruiser remains;
; the rest have moved deeper into the sanctum).
;
; Ports: WEST entry + EAST boss_door.

[ext_resource type="Script" path="res://scripts/levels/LevelChunkDef.gd" id="1_chunk"]
[ext_resource type="Script" path="res://scripts/levels/MobSpawnPoint.gd" id="2_spawn"]
[ext_resource type="Script" path="res://scripts/levels/ChunkPort.gd" id="3_port"]

[sub_resource type="Resource" id="Resource_s2r8_entry"]
script = ExtResource("3_port")
position_tiles = Vector2i(0, 4)
direction = 3
tag = &"entry"

[sub_resource type="Resource" id="Resource_s2r8_boss_door"]
script = ExtResource("3_port")
position_tiles = Vector2i(14, 4)
direction = 1
tag = &"boss_door"

[sub_resource type="Resource" id="Resource_s2r8_scholar_north"]
script = ExtResource("2_spawn")
position_tiles = Vector2i(11, 2)
mob_id = &"sunken_scholar"

[sub_resource type="Resource" id="Resource_s2r8_scholar_south"]
script = ExtResource("2_spawn")
position_tiles = Vector2i(12, 6)
mob_id = &"sunken_scholar"

[sub_resource type="Resource" id="Resource_s2r8_bruiser"]
script = ExtResource("2_spawn")
position_tiles = Vector2i(7, 4)
mob_id = &"bone_catalyst"

[resource]
script = ExtResource("1_chunk")
id = &"s2_room08"
display_name = "Cinder Vaults — Inner Sanctum Threshold"
size_tiles = Vector2i(15, 8)
tile_size_px = 32
scene_path = "res://scenes/levels/chunks/s2_room01_chunk.tscn"
ports = [SubResource("Resource_s2r8_entry"), SubResource("Resource_s2r8_boss_door")]
mob_spawns = [SubResource("Resource_s2r8_scholar_north"), SubResource("Resource_s2r8_scholar_south"), SubResource("Resource_s2r8_bruiser")]
