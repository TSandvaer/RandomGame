[gd_resource type="Resource" script_class="DialogueTreeDef" load_steps=18 format=3]

; W2-T2 hub-town dialogue tree — Sister Ennick, the Storyteller (bounty-giver).
; npc_id: hub_sister_ennick (canonical hub-town id per m3-design-seeds.md §2).
;
; Sister Ennick is the bounty-offering / storyteller NPC — the "explore" voice
; per post-wave3-sequencing.md §1 Commitment 3 (quest-driven exploration tied
; to geography). Her tree exercises the full state-branching set including
; the accept-bounty + complete-bounty quest_action verbs that Track 3 W2
; BountyController consumes for active_bounty / completed_bounties writes.
;
; quest_action verbs:
;   - accept_bounty:s1_recover_stoker_proof  -> writes Player.active_bounty
;   - complete_bounty:s1_recover_stoker_proof -> writes completed_bounties
;   - abandon_bounty                          -> clears active_bounty
;
; Quest id `s1_recover_stoker_proof` is a Track 3 W2 placeholder — the
; canonical quest roster is authored alongside `BountyController` in
; W2-T6 (Track 3). The id is StringName-stable per save-schema-v5-tier3 §2.6
; (no rename once written into a save).

[ext_resource type="Script" path="res://scripts/dialogue/DialogueTreeDef.gd" id="1_tree"]
[ext_resource type="Script" path="res://scripts/dialogue/DialogueBranch.gd" id="2_branch"]
[ext_resource type="Script" path="res://scripts/dialogue/DialogueResponse.gd" id="3_response"]

[sub_resource type="Resource" id="Resource_response_accept"]
script = ExtResource("3_response")
text = "I will bring you proof."
next_branch_key = &"accepted_briefing"
quest_action = &"accept_bounty:s1_recover_stoker_proof"

[sub_resource type="Resource" id="Resource_response_ask_more"]
script = ExtResource("3_response")
text = "Tell me more about the Stokers."
next_branch_key = &"stoker_lore"
quest_action = &""

[sub_resource type="Resource" id="Resource_response_decline"]
script = ExtResource("3_response")
text = "Not today."
next_branch_key = &""
quest_action = &""

[sub_resource type="Resource" id="Resource_response_lore_back"]
script = ExtResource("3_response")
text = "Back."
next_branch_key = &"pre_quest"
quest_action = &""

[sub_resource type="Resource" id="Resource_response_brief_back"]
script = ExtResource("3_response")
text = "I will return when it is done."
next_branch_key = &""
quest_action = &""

[sub_resource type="Resource" id="Resource_response_turn_in"]
script = ExtResource("3_response")
text = "Here is the proof."
next_branch_key = &"completed_thanks"
quest_action = &"complete_bounty:s1_recover_stoker_proof"

[sub_resource type="Resource" id="Resource_response_abandon"]
script = ExtResource("3_response")
text = "I cannot finish. I am sorry."
next_branch_key = &""
quest_action = &"abandon_bounty"

[sub_resource type="Resource" id="Resource_response_completed_done"]
script = ExtResource("3_response")
text = "Until the next road, Sister."
next_branch_key = &""
quest_action = &""

[sub_resource type="Resource" id="Resource_response_flavor_done"]
script = ExtResource("3_response")
text = "Goodnight, Sister."
next_branch_key = &""
quest_action = &""

[sub_resource type="Resource" id="Resource_branch_flavor"]
script = ExtResource("2_branch")
lines = ["Sister Ennick looks up from a book whose pages curl from heat.", "The cloister is quieter than it should be. I am glad you found your way to the lantern."]
responses = [SubResource("Resource_response_flavor_done")]

[sub_resource type="Resource" id="Resource_branch_pre_quest"]
script = ExtResource("2_branch")
lines = ["I keep the lantern lit because I am the only one left who remembers the songs.", "There is something I would ask of you, traveler. Below the cloister, in the Vaults, the Stokers walk again. I need proof one of them fell."]
responses = [SubResource("Resource_response_accept"), SubResource("Resource_response_ask_more"), SubResource("Resource_response_decline")]

[sub_resource type="Resource" id="Resource_branch_stoker_lore"]
script = ExtResource("2_branch")
lines = ["The Stokers tended the great furnace under the cloister. They wore iron the way other men wear cloth.", "When the ember took the cloister, the Stokers did not stop tending the fire. They tend it still. That is the problem."]
responses = [SubResource("Resource_response_lore_back")]

[sub_resource type="Resource" id="Resource_branch_accepted_briefing"]
script = ExtResource("2_branch")
lines = ["Then walk well. The stair down is past the anvil; Brother Voll will let you through.", "Bring me a charred token or a piece of iron with their mark. The ember does not forge - it only burns. I will know."]
responses = [SubResource("Resource_response_brief_back")]

[sub_resource type="Resource" id="Resource_branch_quest_active"]
script = ExtResource("2_branch")
lines = ["Are you well? The Vaults are a hard place even for the ember-blessed.", "Do you have what I asked for?"]
responses = [SubResource("Resource_response_turn_in"), SubResource("Resource_response_abandon")]

[sub_resource type="Resource" id="Resource_branch_completed_thanks"]
script = ExtResource("2_branch")
lines = ["You brought it back. Truly.", "Take what you need from the cloister. The ember tithed less of you than it tithed of me; you are owed."]
responses = [SubResource("Resource_response_completed_done")]

[sub_resource type="Resource" id="Resource_branch_quest_completed"]
script = ExtResource("2_branch")
lines = ["The cloister sleeps quieter since you returned. I am glad of it.", "There will be other bounties. Not today, but soon."]
responses = [SubResource("Resource_response_flavor_done")]

[resource]
script = ExtResource("1_tree")
npc_id = &"hub_sister_ennick"
display_name = "Sister Ennick, the Storyteller"
branches = {
&"flavor": SubResource("Resource_branch_flavor"),
&"pre_quest": SubResource("Resource_branch_pre_quest"),
&"quest_active": SubResource("Resource_branch_quest_active"),
&"quest_completed": SubResource("Resource_branch_quest_completed"),
&"stoker_lore": SubResource("Resource_branch_stoker_lore"),
&"accepted_briefing": SubResource("Resource_branch_accepted_briefing"),
&"completed_thanks": SubResource("Resource_branch_completed_thanks")
}
default_branch_key = &"pre_quest"
