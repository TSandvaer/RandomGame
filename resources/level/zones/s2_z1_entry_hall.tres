[gd_resource type="Resource" script_class="ZoneDef" load_steps=5 format=3]

; W3-T7 Stage 4 — S2 zone wiring (ticket 86c9y7ygj Part C).
;
; Stage 1 (PR #360, merged `14d7c83` 2026-05-24) shipped this as an empty
; geographic shell. Stage 4 populates `anchors` + `procedural_slot_pool`
; against the S2 chunk roster authored in this same PR
; (resources/level_chunks/s2_room01..s2_room08.tres).
;
; Sponsor-locked S2 names (2026-05-24): ranged mob = Sunken-Scholar,
; melee mob = Bone-Catalyst, boss = Archive Sentinel. This zone is the
; descent entry — first place the player sees on S1→S2 transition.
; Tonally substrate-dominant per palette-stratum-2.md §1.6 (80% Cinder
; mining-tunnel, 20% Archive overlay — one scholarly waymarker introduces
; the sub-region without dominating).
;
; Anchors (in zone-graph order):
;   1. entry → s2_room01 (Entry Hall Threshold — 1 Sunken-Scholar
;                          waymarker, substrate-dominant geometry).
;   2. exit  → REUSES s2_room01 chunk geometry; distinct room_id per the
;                ZoneAnchor "two anchors may share chunk geometry, must
;                have distinct room_ids" convention.
;                target_zone_id = &"s2_z2_reading_chamber" (cross-zone
;                mating per level-chunks.md § "Cross-zone transitions").
;
; Procedural slot pool: 1 low-pressure combat chunk (s2_room02 Cinder
; Vaults Mining Cart Bay — Stoker/Charger heat-blasted variants, NOT the
; new Scholar/Catalyst archetypes — z1 deliberately keeps the
; substrate-dominant tone before z2 introduces the Sunken-Scholar). Pool
; size 1 + [0, 1] fill = max 1 fill chunk per gap, 1 gap between the two
; anchors → 1-2 chunks per character per assembly. Lean conservative
; matches s1_z1's SMALL fill range commitment per SI-8 (b).
;
; Cross-references:
;   team/drew-dev/level-chunks.md § "Zone schema" + § "S2 zone roster"
;   team/uma-ux/palette-stratum-2.md §1.6 (entry-hall = substrate-dominant 80/20)

[ext_resource type="Script" path="res://resources/level/ZoneDef.gd" id="1_zone"]
[ext_resource type="Script" path="res://resources/level/ZoneAnchor.gd" id="2_anchor"]

[sub_resource type="Resource" id="Resource_anchor_entry"]
script = ExtResource("2_anchor")
room_id = &"s2_z1_threshold"
chunk_id = &"s2_room01"
anchor_kind = &"entry"
target_zone_id = &""

[sub_resource type="Resource" id="Resource_anchor_exit"]
script = ExtResource("2_anchor")
room_id = &"s2_z1_descent_to_reading"
chunk_id = &"s2_room01"
anchor_kind = &"exit"
target_zone_id = &"s2_z2_reading_chamber"

[resource]
script = ExtResource("1_zone")
zone_id = &"s2_z1_entry_hall"
display_name = "Entry Hall of the Archive"
stratum_id = 2
anchors = [SubResource("Resource_anchor_entry"), SubResource("Resource_anchor_exit")]
procedural_slot_pool = [&"s2_room02"]
min_slots_between_anchors = 0
max_slots_between_anchors = 1
port_mating_rules = {}
