[gd_resource type="Resource" script_class="ZoneDef" load_steps=6 format=3]

; W3-T7 Stage 4 — S2 zone wiring (ticket 86c9y7ygj Part C).
;
; Sponsor-locked S2 names (2026-05-24). This zone is the late-stratum /
; boss-approach zone — final corridor before the Stratum2BossRoom
; encounter (Part D, Stage 5 ticket). Substrate-reclaims weighting per
; palette-stratum-2.md §1.6 (70% Cinder, 30% overlay — the scholarly
; identity is failing here; the cinder is winning. The Archive Sentinel
; guards what remains.).
;
; Anchors (in zone-graph order):
;   1. entry     → s2_room07 (Pincer Reliquary — 2 Bone-Catalyst + 1
;                             Sunken-Scholar; high-pressure trial gauntlet
;                             at the zone entry).
;   2. boss_room → s2_room08 (Inner Sanctum Threshold — 2 Sunken-Scholar
;                             + 1 Bone-Catalyst, EAST = `&"boss_door"`
;                             tag. The boss_room anchor's chunk is the
;                             antechamber leading INTO the boss arena;
;                             Stratum2BossRoom.tscn itself is a separate
;                             scene wired via the boss_door port in
;                             Stage 5/Part D).
;   3. exit      → REUSES s2_room08 chunk geometry; distinct room_id.
;                 target_zone_id = &"" (terminal exit for M3 Tier 3;
;                 future S3 zones will set target_zone_id once authored.
;                 The assembler treats unresolved/empty target_zone_id as
;                 a terminal exit per level-chunks.md § "Cross-zone
;                 transitions").
;
; Procedural slot pool: 2 high-pressure chunks — s2_room07 (pincer
; gauntlet) + s2_room06 (reliquary hall). Both consume the new
; Sunken-Scholar + Bone-Catalyst archetypes, no substrate-only chunks in
; this pool — the boss-approach zone is meant to feel maximally hostile.
;
; Cross-references:
;   team/drew-dev/level-chunks.md § "Zone schema" + § "S2 zone roster"
;   team/uma-ux/palette-stratum-2.md §1.6 (inner-sanctum = substrate-reclaims 70/30)
;   .claude/docs/audio-architecture.md § "Tonal pattern — cross-stratum
;     distinct ambient" (S2 boss music = distinct composition; ticket
;     Part D Stage 5 lands the boss-room + Archive Sentinel)

[ext_resource type="Script" path="res://resources/level/ZoneDef.gd" id="1_zone"]
[ext_resource type="Script" path="res://resources/level/ZoneAnchor.gd" id="2_anchor"]

[sub_resource type="Resource" id="Resource_anchor_entry"]
script = ExtResource("2_anchor")
room_id = &"s2_z4_pincer_entry"
chunk_id = &"s2_room07"
anchor_kind = &"entry"
target_zone_id = &""

[sub_resource type="Resource" id="Resource_anchor_boss"]
script = ExtResource("2_anchor")
room_id = &"s2_z4_sanctum_threshold"
chunk_id = &"s2_room08"
anchor_kind = &"boss_room"
target_zone_id = &""

[sub_resource type="Resource" id="Resource_anchor_exit"]
script = ExtResource("2_anchor")
room_id = &"s2_z4_sanctum_descent"
chunk_id = &"s2_room08"
anchor_kind = &"exit"
target_zone_id = &""

[resource]
script = ExtResource("1_zone")
zone_id = &"s2_z4_inner_sanctum"
display_name = "Inner Sanctum"
stratum_id = 2
anchors = [SubResource("Resource_anchor_entry"), SubResource("Resource_anchor_boss"), SubResource("Resource_anchor_exit")]
procedural_slot_pool = [&"s2_room07", &"s2_room06"]
min_slots_between_anchors = 0
max_slots_between_anchors = 1
port_mating_rules = {}
