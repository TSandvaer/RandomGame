[resource]
script = ExtResource("1_zone")
zone_id = &"s1_z1_outer_cloister"
display_name = "Outer Cloister"
stratum_id = 1
anchors = [SubResource("Resource_anchor_entry"), SubResource("Resource_anchor_npc_antechamber"), SubResource("Resource_anchor_story_chargers_run"), SubResource("Resource_anchor_quest_marksmans_perch"), SubResource("Resource_anchor_story_crossfire_yard"), SubResource("Resource_anchor_npc_hallowed_spring"), SubResource("Resource_anchor_story_pincer_hall"), SubResource("Resource_anchor_boss"), SubResource("Resource_anchor_exit")]
procedural_slot_pool = [&"s1_room03", &"s1_room05", &"s1_room07"]
min_slots_between_anchors = 0
max_slots_between_anchors = 1
port_mating_rules = {}
