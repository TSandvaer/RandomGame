[gd_resource type="Resource" script_class="ZoneDef" load_steps=2 format=3]

; W3-T7 Stage 1 — S2 ZoneDef authoring (Part A only; ticket `86c9y7ygj`).
;
; This file is the geographic SHELL — anchors + procedural_slot_pool are
; left empty per the Stage 1 dispatch brief. Parts B (S2 mobs), C (S2
; chunks), and D (S2 boss room) ship in later PRs.
;
; Sponsor-locked S2 names (2026-05-24): ranged mob = Sunken-Scholar.
; This zone is the early-stratum exploration zone — first place where the
; Sunken-Scholar archetype appears (per ticket Part B). Tonally a quieter
; sub-area: low-pressure beat between the entry hall and the archive
; vault, room for an NPC encounter (post-wave3-sequencing.md §6 SI-5: S2
; carries 2 stratum NPCs; one will likely anchor here in Part C).
;
; TODO Part C: populate `anchors` (entry + ≥1 exit + npc_room slot for
; the SI-5 NPC) and `procedural_slot_pool` with low-pressure combat
; chunks per FloorAssembler.assemble_floor.
;
; Cross-references:
;   team/drew-dev/level-chunks.md § "Zone schema" + § "S2 zone roster"
;   team/uma-ux/palette-stratum-2.md (S2 doctrine palette)

[ext_resource type="Script" path="res://resources/level/ZoneDef.gd" id="1_zone"]

[resource]
script = ExtResource("1_zone")
zone_id = &"s2_z2_reading_chamber"
display_name = "Sunken Reading Chamber"
stratum_id = 2
anchors = []
procedural_slot_pool = []
