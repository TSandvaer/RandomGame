# Godot 4
.godot/
*.import
*.translation
export.cfg
# NOTE: export_presets.cfg is intentionally NOT ignored — it's the contract
# the CI release workflows (release-itch.yml, release-github.yml) consume to
# produce HTML5 / Windows / macOS / Linux builds. Keep it under VCS.

# CI-stamped build identification (BuildInfo autoload). Generated per-build
# by .github/workflows/ci.yml and release-itch.yml. Local dev runs
# without this file and BuildInfo falls back to "dev-local".
build_info.txt

# Build outputs
build/
exports/
dist/
*.exe
*.dmg
*.zip
*.pck
*.tar.gz

# Extracted HTML5 build dirs that agents create in worktrees (diagnostic
# builds, AC-verification artifact extracts). These are ~8-38MB unpacked
# zips — never commit them; a stray `git add -A` would otherwise stage them.
diag-build/
.ac4-artifact/
.artifact-extract/
html5-build-extract/
# Per-agent scratch dir for soak extracts, screenshot drafts, self-test artifacts.
# Created by agents during self-soak / probe work — must never commit.
# Match at any depth (top-level worktree OR tests/playwright/.claude/tmp/).
**/.claude/tmp/

# IDE / editors
.vscode/
.idea/
*.swp
*.swo
*~

# OS
Thumbs.db
.DS_Store
desktop.ini

# Secrets / local
.env
.env.local
*.local

# Node (CI tooling, Aseprite scripts, etc.)
node_modules/
npm-debug.log

# Python (asset tooling)
__pycache__/
*.pyc
.venv/
venv/

# Logs
*.log

# Claude Code — versioned project config + skills + docs + hooks live in .claude/
# Per-user / per-machine state is excluded individually below.
.claude/settings.local.json
.claude/scheduled_tasks.lock
.claude/scheduled_tasks.json
.claude/auto-status.state
.claude/auto-pixellab.state
# AWAY-mode autonomy audit log — per-machine, the orchestrator appends a row
# before any auto-decided action; user reviews on return.
.claude/decisions-while-away.md

# Stray local-server pid file (created by ad-hoc dev-server invocations).
server.pid
